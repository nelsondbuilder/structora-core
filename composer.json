{
  "name": "structora/core",
  "description": "Read-only structure intelligence and workflow discovery engine.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "structure-analysis",
    "workflow-discovery",
    "dom-analysis",
    "developer-tools",
    "read-only"
  ],
  "autoload": {
    "psr-4": {
      "Structora\\": "src/"
    }
  },
  "bin": [
    "bin/structora"
  ],
  "require": {
    "php": ">=8.1",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0"
  },
  "scripts": {
    "test": "phpunit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
