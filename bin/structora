#!/usr/bin/env php
<?php

declare(strict_types=1);

use Structora\Core\DiscoveryEngine;
use Structora\Core\DiscoveryOptions;
use Structora\Core\DiscoveryResult;
use Structora\Rendering\StaticHtmlRenderer;

require dirname(__DIR__) . '/vendor/autoload.php';

function printHelp(): void
{
    echo "Structora Core\n";
    echo "Read-only structure intelligence and workflow discovery for local HTML input.\n\n";
    echo "Usage:\n";
    echo "  structora discover <source-label>\n";
    echo "  structora discover-file <path>\n";
    echo "  structora inspect-file <path>\n";
    echo "  structora summary-file <path>\n";
    echo "  structora render-file <path>\n";
    echo "  structora inspect-render <path>\n";
    echo "  structora version\n";
    echo "  structora help\n\n";
    echo "Safety:\n";
    echo "  Local files only. No remote fetching, browser actions, form submission, or workflow execution.\n";
}

function writeJson(array $payload): void
{
    echo json_encode(
        $payload,
        JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_THROW_ON_ERROR
    ) . PHP_EOL;
}

function fail(string $message, int $exitCode = 1): never
{
    fwrite(STDERR, "Structora error: {$message}\n");
    exit($exitCode);
}

function resolveLocalHtmlFile(string $path): string
{
    if ($path === '') {
        fail('Missing local file path.');
    }

    if (preg_match('/^[a-z][a-z0-9+.-]*:\/\//i', $path) === 1) {
        fail('Remote URLs are not supported. Provide a local HTML file path.');
    }

    $resolvedPath = realpath($path);
    if ($resolvedPath === false) {
        fail("File not found: {$path}");
    }

    if (!is_file($resolvedPath)) {
        fail("Path is not a file: {$path}");
    }

    if (!is_readable($resolvedPath)) {
        fail("File is not readable: {$path}");
    }

    return $resolvedPath;
}

function readLocalHtmlFile(string $path): array
{
    $resolvedPath = resolveLocalHtmlFile($path);
    $html = file_get_contents($resolvedPath);

    if ($html === false) {
        fail("Unable to read file: {$path}");
    }

    return [$resolvedPath, $html];
}

function discoverLocalFile(string $path, string $command, bool $render = false): DiscoveryResult
{
    [$resolvedPath, $html] = readLocalHtmlFile($path);
    $engine = new DiscoveryEngine();

    if ($render) {
        $engine = $engine->withRenderer(new StaticHtmlRenderer());
    }

    return $engine->discover(
        $html,
        DiscoveryOptions::fromArray([
            'source' => $resolvedPath,
            'rendering_enabled' => $render,
            'metadata' => [
                'input_type' => 'local_file',
                'command' => $command,
            ],
        ])
    );
}

function inspectPayload(array $payload): array
{
    return [
        'schema_version' => $payload['schema_version'],
        'generated_at' => $payload['generated_at'],
        'status' => $payload['status'],
        'source' => $payload['source'],
        'title' => $payload['title'],
        'summary' => $payload['summary'],
        'metadata' => $payload['metadata'],
        'rendering' => $payload['rendering'],
        'forms' => $payload['forms'],
        'links' => $payload['links'],
        'headings' => $payload['headings'],
        'signals' => $payload['signals'],
        'signal_summary' => $payload['signal_summary'],
        'workflow' => $payload['workflow'],
        'workflow_summary' => $payload['workflow_summary'],
    ];
}

function summaryPayload(array $payload): array
{
    return [
        'schema_version' => $payload['schema_version'],
        'generated_at' => $payload['generated_at'],
        'source' => $payload['source'],
        'title' => $payload['title'],
        'summary' => [
            'form_count' => $payload['summary']['form_count'],
            'field_count' => $payload['summary']['field_count'],
            'button_count' => $payload['summary']['button_count'],
            'link_count' => $payload['summary']['link_count'],
            'heading_count' => $payload['summary']['heading_count'],
            'signal_count' => $payload['summary']['signal_count'],
            'signal_types' => $payload['summary']['signal_types'],
            'workflow_count' => $payload['summary']['workflow_count'],
            'workflow_types' => $payload['summary']['workflow_types'],
            'rendered' => $payload['summary']['rendered'],
            'render_strategy' => $payload['summary']['render_strategy'],
        ],
        'rendering' => [
            'rendered' => $payload['rendering']['rendered'],
            'strategy' => $payload['rendering']['strategy'],
            'duration_ms' => $payload['rendering']['duration_ms'],
            'document_length' => $payload['rendering']['document_length'],
        ],
        'signal_confidence' => $payload['signal_summary']['confidence'],
        'workflow_confidence' => $payload['workflow_summary']['confidence_summary'],
        'read_only' => $payload['metadata']['read_only'],
        'non_executable' => $payload['workflow_summary']['non_executable'],
    ];
}

$command = $argv[1] ?? 'help';

if ($command === 'help' || in_array($command, ['-h', '--help'], true)) {
    printHelp();
    exit(0);
}

if ($command === 'version') {
    writeJson([
        'name' => 'structora/core',
        'version' => DiscoveryResult::SCHEMA_VERSION,
        'schema_version' => DiscoveryResult::SCHEMA_VERSION,
        'read_only' => true,
    ]);
    exit(0);
}

if ($command === 'discover') {
    $source = $argv[2] ?? 'cli-input';
    $result = (new DiscoveryEngine())->discover(
        '<html><body><main>Structora scaffold input</main></body></html>',
        DiscoveryOptions::fromArray([
            'source' => $source,
        ])
    );

    writeJson($result->toArray());
    exit(0);
}

if ($command === 'render-file') {
    [$resolvedPath, $html] = readLocalHtmlFile($argv[2] ?? '');
    $result = (new StaticHtmlRenderer())->render($html, [
        'source' => $resolvedPath,
        'metadata' => [
            'input_type' => 'local_file',
            'command' => $command,
        ],
    ]);

    writeJson([
        'schema_version' => DiscoveryResult::SCHEMA_VERSION,
        'source' => $resolvedPath,
        'rendering' => $result->toArray(includeHtml: false),
        'rendered_summary' => [
            'rendered' => $result->metadata->rendered,
            'strategy' => $result->metadata->strategy,
            'duration_ms' => $result->metadata->durationMs,
            'document_length' => strlen($result->document->html),
            'read_only' => true,
            'non_executable' => true,
        ],
    ]);
    exit(0);
}

if (in_array($command, ['discover-file', 'inspect-file', 'summary-file', 'inspect-render'], true)) {
    $render = $command === 'inspect-render';
    $result = discoverLocalFile($argv[2] ?? '', $command, $render);
    $payload = $result->toArray();

    if ($command === 'inspect-file' || $command === 'inspect-render') {
        $payload = inspectPayload($payload);
    }

    if ($command === 'summary-file') {
        $payload = summaryPayload($payload);
    }

    writeJson($payload);
    exit(0);
}

fail("Unknown command: {$command}");
